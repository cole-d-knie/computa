      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${COMPUTA_REPO:-/Users/cole/Desktop/swarm-verify-skills}/scripts/computa_hooks.py hook --format codex --event UserPromptSubmit --expand-queue"
